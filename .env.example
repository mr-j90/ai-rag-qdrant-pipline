# --- API keys ---
VOYAGE_API_KEY=your_voyage_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=documents

# --- Embeddings ---
# voyage-3 = 1024 dim, balanced cost/quality
# voyage-3-large = 1024 dim, highest quality
VOYAGE_MODEL=voyage-3
EMBEDDING_DIM=1024

# --- Generation ---
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Chunking (LlamaIndex SentenceSplitter, sizes are in TOKENS) ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

AZURE_BLOB_CONNECTION_STRING=REPLACE_WITH_YOUR_CONNECTION_STRING
AZURE_BLOB_CONTAINER=REPLACE_WITH_YOUR_CONTAINER_NAME